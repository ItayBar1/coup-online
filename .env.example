# ─── Server (runtime) ──────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=production
# Log verbosity: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=info

# ─── Docker Compose ─────────────────────────────────────────────────────────────
# Host port to bind (maps to container port 8000)
HOST_PORT=8000

# GHCR image to pull (set by CI; override for local builds)
# Format: ghcr.io/<github-owner>/<repo>
GITHUB_REPOSITORY=itaybar1/coup-online
IMAGE_TAG=latest


COUP_TUNNEL_TOKEN=**************

# ─── Frontend (Vite build-time) ─────────────────────────────────────────────────
# Leave empty when server and client share the same origin (recommended for Docker).
# Set to your public URL only when running frontend separately.
VITE_BACKEND_URL=""

# Client-side log verbosity: DEBUG | INFO | WARN | ERROR (defaults to WARN in prod)
VITE_LOG_LEVEL=warn

# ─── Optional: Google Analytics ─────────────────────────────────────────────────
# VITE_GOOGLE_TRACKING_ID=G-XXXXXXXXXX
